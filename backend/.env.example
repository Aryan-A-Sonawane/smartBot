# ===== Required =====
# Google Gemini API key — get one free at https://aistudio.google.com/apikey
# NOTE: put your real key in `.env` (gitignored), NOT here. This file is a
# committed template and must never contain a real secret.
GEMINI_API_KEY=

# ===== Optional (sensible defaults) =====
# Fast model for most calls; "pro" model for hard/ambiguous reasoning.
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

# Flash-only by default (pro has much lower rate limits). Set to true to let
# hard/ambiguous tasks escalate to the pro model + enable flash->pro fallback.
GEMINI_USE_PRO=false

# Embedding model for RAG retrieval (document Q&A over large docs).
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# Comma-separated list of allowed frontend origins for CORS.
# Use the Vercel URL in production, e.g. https://smartbot.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# faster-whisper model size: tiny | base | small | medium
WHISPER_MODEL=base

# Reject uploads larger than this (megabytes).
MAX_FILE_MB=25

# Reject audio clips longer than this many minutes (memory guard for small hosts;
# set to ~10 on a 512 MB instance, higher when running locally / on a bigger plan).
MAX_AUDIO_MINUTES=30
